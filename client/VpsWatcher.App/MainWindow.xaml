<Window x:Class="VpsWatcher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VpsWatcher.App.ViewModels"
        xmlns:conv="clr-namespace:VpsWatcher.App.Converters"
        Title="VPS監視-Mei"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="{Binding AlwaysOnTop}"
        WindowStartupLocation="CenterScreen">
    <!-- Phase 6a: compact gadget. Graphs (ProgressBars) are gone; each metric is icon + value, the
         value coloured by its own alert band (§6). Fixed 200px wide, height grows with server count.
         Character stands above the server list; servers stack up from her feet (§5.2/§5.3). -->

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:AlertLevelToBrushConverter x:Key="LevelBrush" />

        <!-- Decoded once + frozen on load (§13.2): one shared instance per image, reused by every
             binding so there is no per-frame allocation or redecoding. The character portrait is no
             longer a static resource — it's supplied (cached/frozen) by CharacterImageProvider and
             swapped by state via MainViewModel.CharacterImage (§8). -->
        <BitmapImage x:Key="IconCpu" UriSource="pack://application:,,,/VpsWatcher.App;component/Assets/icon/cpu.png"
                     CacheOption="OnLoad" DecodePixelWidth="28" />
        <BitmapImage x:Key="IconMem" UriSource="pack://application:,,,/VpsWatcher.App;component/Assets/icon/memory.png"
                     CacheOption="OnLoad" DecodePixelWidth="28" />
        <BitmapImage x:Key="IconDisc" UriSource="pack://application:,,,/VpsWatcher.App;component/Assets/icon/disc.png"
                     CacheOption="OnLoad" DecodePixelWidth="28" />
        <BitmapImage x:Key="IconSwap" UriSource="pack://application:,,,/VpsWatcher.App;component/Assets/icon/swap.png"
                     CacheOption="OnLoad" DecodePixelWidth="28" />

        <!-- Compact, fixed-width numeric cell (monospace so digits line up under the icons). -->
        <Style x:Key="MetricNum" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,2,0" />
        </Style>

        <!-- One header icon, right-aligned with the same right margin as the numbers below it so the
             icon sits visually over its (right-aligned) value column (Phase 6b §2). -->
        <Style x:Key="HeaderIcon" TargetType="Image">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <!-- Flat title-bar buttons. -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Foreground" Value="#D8DCE2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PinToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Foreground" Value="#D8DCE2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="ToolTip" Value="最前面に固定（ON/OFF）" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                            <TextBlock x:Name="glyph" Text="📌" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Opacity="0.55" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#3354A0FF" />
                                <Setter TargetName="glyph" Property="Opacity" Value="1.0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Opaque rounded panel = the visible, grabbable, hit-testable gadget body. Fixed 200px wide.
         Background alpha comes from appearance.json background_opacity (§5); fallback brush keeps the
         original look if the ViewModel hasn't supplied one. -->
    <Border Width="200" CornerRadius="12" Padding="10,8"
            Background="{Binding BackgroundBrush, TargetNullValue=#E61E2228, FallbackValue=#E61E2228}"
            BorderBrush="#33FFFFFF" BorderThickness="1">
        <StackPanel>

            <!-- Title bar: drag handle (left, fills) + pin + close (right). -->
            <Grid Height="22" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border x:Name="DragHandle" Grid.Column="0" Background="Transparent"
                        MouseLeftButtonDown="DragHandle_MouseLeftButtonDown" Cursor="SizeAll">
                    <TextBlock Text="⠿ VPS監視-Mei" Foreground="#9AA1AA" FontSize="10"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ToggleButton Style="{StaticResource PinToggle}" IsChecked="{Binding AlwaysOnTop}" />
                    <Button Style="{StaticResource CaptionButton}" Content="✕"
                            Click="Close_Click" ToolTip="閉じる" />
                </StackPanel>
            </Grid>

            <!-- Empty state (no server / config missing). -->
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#FF8A80"
                       FontSize="11" />

            <!-- Character (Phase 6b): portrait swaps with the worst-of state via CharacterImage (§8).
                 Servers stack up from her feet — she sits directly above the icon header + rows.
                 Phase 6c: clicking her speaks the current worst-of status (§4). Hit-testing is the
                 image bounds, separate from the title-bar drag handle, so it can't fight a drag. -->
            <Image Source="{Binding CharacterImage}" Width="140" HorizontalAlignment="Center"
                   Margin="0,0,0,-4" Stretch="Uniform" Cursor="Hand"
                   ToolTip="クリックで現在の状態を読み上げ"
                   Visibility="{Binding HasServer, Converter={StaticResource BoolToVis}}">
                <Image.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CharacterClickCommand}" />
                </Image.InputBindings>
            </Image>

            <StackPanel Visibility="{Binding HasServer, Converter={StaticResource BoolToVis}}">

                <!-- Shared icon header (once): each icon is the heading of the number column below it.
                     Columns here MUST match the server-row columns for the icons to sit over the
                     numbers (id 54 + four 31px metric columns = 178 inner width). -->
                <Grid Margin="0,2,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="54" />
                        <ColumnDefinition Width="31" />
                        <ColumnDefinition Width="31" />
                        <ColumnDefinition Width="31" />
                        <ColumnDefinition Width="31" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="1" Style="{StaticResource HeaderIcon}" Source="{StaticResource IconCpu}"  ToolTip="CPU" />
                    <Image Grid.Column="2" Style="{StaticResource HeaderIcon}" Source="{StaticResource IconMem}"  ToolTip="メモリ" />
                    <Image Grid.Column="3" Style="{StaticResource HeaderIcon}" Source="{StaticResource IconDisc}" ToolTip="ディスク（/）" />
                    <Image Grid.Column="4" Style="{StaticResource HeaderIcon}" Source="{StaticResource IconSwap}" ToolTip="Swap" />
                </Grid>

                <!-- N server rows, stacked. Each = a main row (id + 4 numbers) plus sub-rows for any
                     non-root disks. -->
                <ItemsControl ItemsSource="{Binding Servers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ServerViewModel}">
                          <Border Margin="0,1" Padding="0,1" ToolTip="{Binding StateText}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <!-- Stale connection: dim the whole row so the numbers read as
                                             "no longer live" (§5.4). Mismatch stays full so its warning
                                             colour is not muted. -->
                                        <DataTrigger Binding="{Binding IsDisconnected}" Value="True">
                                            <Setter Property="Opacity" Value="0.5" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>

                                <!-- Main row: identifier + cpu / mem / disk(/) / swap numbers. -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54" />
                                        <ColumnDefinition Width="31" />
                                        <ColumnDefinition Width="31" />
                                        <ColumnDefinition Width="31" />
                                        <ColumnDefinition Width="31" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Identifier (≤8 chars, label-based). Colour reflects connection
                                         state; a host-key mismatch adds a purple ⚠ (full warning text
                                         is in the row tooltip to stay compact). -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⚠" FontSize="11" Foreground="#B06BFF" Margin="0,0,1,0"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsHostKeyMismatch, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding ShortId}" FontFamily="Consolas" FontSize="11"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                                   ToolTip="{Binding Label}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <!-- Base colour follows the panel opacity (light, or dark when
                                                         faint) via the window's PrimaryTextBrush (§3). -->
                                                    <Setter Property="Foreground"
                                                            Value="{Binding DataContext.PrimaryTextBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDisconnected}" Value="True">
                                                            <Setter Property="Foreground" Value="#9AA1AA" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsHostKeyMismatch}" Value="True">
                                                            <Setter Property="Foreground" Value="#B06BFF" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Style="{StaticResource MetricNum}"
                                               Text="{Binding CpuPctText}"
                                               Foreground="{Binding CpuLevel, Converter={StaticResource LevelBrush}}" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource MetricNum}"
                                               Text="{Binding MemPctText}"
                                               Foreground="{Binding MemLevel, Converter={StaticResource LevelBrush}}" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource MetricNum}"
                                               Text="{Binding RootDiskPctText}"
                                               Foreground="{Binding RootDiskLevel, Converter={StaticResource LevelBrush}}" />
                                    <TextBlock Grid.Column="4" Style="{StaticResource MetricNum}"
                                               Text="{Binding SwapPctText}"
                                               Foreground="{Binding SwapLevel, Converter={StaticResource LevelBrush}}" />
                                </Grid>

                                <!-- Sub-rows for non-root disks: mount name (id column) + its % under
                                     the disc icon column. Root is shown on the main row, so it is
                                     collapsed here. -->
                                <ItemsControl ItemsSource="{Binding Disks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:DiskGaugeViewModel}">
                                            <Grid>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRoot}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="54" />
                                                    <ColumnDefinition Width="31" />
                                                    <ColumnDefinition Width="31" />
                                                    <ColumnDefinition Width="31" />
                                                    <ColumnDefinition Width="31" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Mount}" ToolTip="{Binding UsedText}"
                                                           FontFamily="Consolas" FontSize="10" Foreground="#9AA1AA"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Style="{StaticResource MetricNum}"
                                                           Text="{Binding PctText}"
                                                           Foreground="{Binding Level, Converter={StaticResource LevelBrush}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
